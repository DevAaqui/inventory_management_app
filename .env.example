# Copy to .env and fill in real values:
#   cp .env.example .env

# MySQL connection URL (user, password, host, port, database name)
# Example: mysql://root:secret@127.0.0.1:3306/stockflow
DATABASE_URL="mysql://USER:PASSWORD@127.0.0.1:3306/DATABASE_NAME"

# iron-session: must be at least 32 characters; use a long random string in production
SESSION_PASSWORD="change-me-to-a-random-string-at-least-32-chars"
